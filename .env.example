# API Configuration
# The base URL for your backend API (Render URL in production)
# Example: https://your-backend.onrender.com/api
VITE_API_BASE_URL=http://localhost:5000/api

# Main Domain Configuration
# The frontend domain (without subdomain) used for tenant routing
# Local development: localhost:5173
# Production: yourdomain.com or clinic.vercel.app
VITE_MAIN_DOMAIN=localhost:5173

# Cloudinary Configuration (required for image/file uploads)
# Get these from https://cloudinary.com/console
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset