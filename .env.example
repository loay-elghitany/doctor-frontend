# =============================================================================
# FRONTEND ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and configure for your environment.
# For production deployment instructions, see DEPLOYMENT_VARS.md
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# The base URL for your backend API.
# - Development: http://localhost:5000/api
# - Production: Your Render backend URL (e.g., https://your-backend.onrender.com/api)
# IMPORTANT: Must include the /api suffix
VITE_API_BASE_URL=http://localhost:5000/api

# -----------------------------------------------------------------------------
# Main Domain Configuration (REQUIRED for subdomain routing)
# -----------------------------------------------------------------------------
# The frontend domain (without subdomain) used for tenant routing.
# - Development: localhost:5173
# - Production with Vercel: yourdomain.com (e.g., mydoc90.com)
# - Production with Vercel free tier: your-app.vercel.app
# IMPORTANT: This must match the MAIN_DOMAIN setting in your backend
VITE_MAIN_DOMAIN=localhost:5173

# -----------------------------------------------------------------------------
# Cloudinary Configuration (Optional - for file/image uploads)
# -----------------------------------------------------------------------------
# Get these from https://cloudinary.com/console
# These are required if your app supports file uploads
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================
# For Vercel deployment:
# 1. Set VITE_API_BASE_URL to your Render backend URL
# 2. Set VITE_MAIN_DOMAIN to your custom domain (e.g., mydoc90.com)
# 3. Add these variables in Vercel: Settings > Environment Variables
# 4. Redeploy after adding environment variables
#
# See DEPLOYMENT_VARS.md for complete deployment instructions
# =============================================================================
